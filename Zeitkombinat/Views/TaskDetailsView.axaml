<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zeitkombinat.ViewModels"
             xmlns:controls="clr-namespace:Zeitkombinat.Controls"
             x:Class="Zeitkombinat.Views.TaskDetailsView">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,20">
            <!-- Task Display Section -->
            <StackPanel Name="TaskDisplayPanel" Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Name="TaskTitle" FontSize="18" FontWeight="Bold"/>
                    <Button Content="Edit" Click="EditTask_Click"/>
                </StackPanel>
                <TextBlock Name="TaskDescription"/>
                <HyperlinkButton 
                    Name="TaskLinkButton"
                    NavigateUri="--" 
                    Width="350"
                    Padding="0 5">
                    <TextBlock Name="TaskLinkLabel" Text="--" Margin="0" />
                </HyperlinkButton>
                <TextBlock Name="TaskHours" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Task Edit Section -->
            <StackPanel Name="TaskEditPanel" Spacing="5" IsVisible="False">
                <TextBlock Text="Edit Task" FontSize="18" FontWeight="Bold"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="TaskNameEdit" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="TaskDescriptionEdit" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Link:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Name="TaskLinkEdit" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Estimated:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <controls:TimeSpanInput Grid.Row="3" Grid.Column="1" Name="TaskEstimatedEdit" Margin="0,0,0,5"/>

                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Save" Click="SaveTask_Click"/>
                        <Button Content="Cancel" Click="CancelTaskEdit_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Separator Margin="0,20,0,10"/>
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0 0 50 0">
                    <TextBlock Text="Add New Work Session"/>
                    <Button Content="Start New Session" Click="StartSession_Click" HorizontalAlignment="Left" Margin="0,5,0,10"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Or Add Completed Session:"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,5,0,0">
                        <TextBlock Grid.Column="0" Text="Duration:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <controls:TimeSpanInput Grid.Column="1" Name="DurationInput" Margin="0,0,10,0"/>
                        <Button Grid.Column="2" Content="Add Session" Click="AddCompletedSession_Click" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <Separator Margin="0,20,0,10"/>

            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0 0 50 0">
                    <TextBlock Text="Open Work Sessions"/>
                    <ItemsControl Name="OpenSessionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:WorkSessionViewModel">
                                <Border BorderThickness="2" Margin="0,5" Padding="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                        <Button Content="Close Session" Click="CloseSession_Click" Tag="{Binding Session}" VerticalAlignment="Center"/>
                                        <Button Content="Delete" Click="DeleteSession_Click" Tag="{Binding Session}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                
                <StackPanel>
                    <TextBlock Text="Completed Work Sessions"/>
                    <ScrollViewer>
                        <ItemsControl Name="CompletedSessionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:WorkSessionViewModel">
                                    <Border BorderThickness="1" Margin="0,5" Padding="10">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                            <Button Content="Delete" Click="DeleteSession_Click" Tag="{Binding Session}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</UserControl>
