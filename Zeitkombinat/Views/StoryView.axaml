<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Zeitkombinat.Controls"
             xmlns:vm="using:Zeitkombinat.ViewModels"
             xmlns:views="clr-namespace:Zeitkombinat.Views"
             x:Class="Zeitkombinat.Views.StoryView">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,20">
            <!-- Story Details Section -->
            <StackPanel Name="StoryDisplayPanel" Spacing="5" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Name="StoryName" FontSize="18" FontWeight="Bold" />
                    <Button Content="Edit" Click="EditStory_Click" />
                </StackPanel>
                <TextBlock Name="StoryDescription" />
                <HyperlinkButton
                    Name="StoryLinkButton"
                    NavigateUri="--"
                    Width="350"
                    Padding="0 5">
                    <TextBlock Name="StoryLinkLabel" Text="--" Margin="0" />
                </HyperlinkButton>
            </StackPanel>

            <!-- Story Edit Section -->
            <StackPanel Name="StoryEditPanel" Spacing="5" Margin="0,0,0,20" IsVisible="False">
                <TextBlock Text="Edit Story" FontSize="18" FontWeight="Bold" />
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBox Grid.Row="0" Grid.Column="1" Name="StoryNameEdit" Margin="0,0,0,5" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBox Grid.Row="1" Grid.Column="1" Name="StoryDescriptionEdit" Margin="0,0,0,5" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Link:" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBox Grid.Row="2" Grid.Column="1" Name="StoryLinkEdit" Margin="0,0,0,5" />

                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Save" Click="SaveStory_Click" />
                        <Button Content="Cancel" Click="CancelStoryEdit_Click" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Separator Margin="0,0,0,10" />
            <StackPanel Orientation="Horizontal">
                <CheckBox Name="ShowCompletedCheckBox" Content="Show completed" Margin="0,0,5,0" Click="ShowCompletedCheckBox_OnClick" />
                <TextBox Name="SearchTextBox" Watermark="Search tasks..." Margin="0,0,0,5" TextChanged="SearchTextBox_OnTextChanged" />
            </StackPanel>
        </StackPanel>
       
        <StackPanel Orientation="Horizontal">
            <ScrollViewer>
                <StackPanel>
                    <Button Name="AddTaskToggleButton" Content="Add Task" Click="AddTaskToggleButton_OnClick" Margin="0,0,0,5" />
                    <Grid Name="AddTaskForm" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0" IsVisible="False">
                        <TextBox Grid.Row="0" Grid.Column="0" Name="TaskNameInput" Watermark="Task name" Margin="0,0,10,2" />
                        <TextBox Grid.Row="1" Grid.Column="0" Name="DescriptionInput" Watermark="Task description" Margin="0,0,10,2" />
                        <TextBox Grid.Row="2" Grid.Column="0" Name="HyperLinkInput" Watermark="Optional hyperlink" Margin="0,0,10,2" />
                        <controls:TimeSpanInput Grid.Row="3" Grid.Column="0" Name="EstimatedInput" Margin="0,0,10,5" />
                        <Button Grid.Row="4" Grid.Column="0" Content="Add Task" Click="AddTask_Click" VerticalAlignment="Center" />
                    </Grid>
                    
                    <ItemsControl Name="TasksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:TaskViewModel">
                                <Border BorderThickness="1" Margin="0,5" Padding="10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <CheckBox IsChecked="{Binding IsDone}" Click="TaskDoneCheckBox_OnClick" Tag="{Binding Task}" />
                                            <TextBlock Text="{Binding Name}" Classes="h2" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" Margin="0,5,0,0" />

                                        <HyperlinkButton
                                            NavigateUri="{Binding RawLink}"
                                            Width="350"
                                            Padding="0 5"
                                            IsVisible="{Binding HasLink}">
                                            <TextBlock Text="{Binding LinkText}" Margin="0" />
                                        </HyperlinkButton>

                                        <TextBlock Margin="0,5,0,0" Classes="sub" IsVisible="{Binding HasOpenSessions}">
                                            <Run Text="{Binding HoursText}" />
                                            <Run Text=" - Open Sessions: " Classes="warning" />
                                            <Run Text="{Binding OpenSessionsDuration}" Classes="warning" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding HoursText}" Margin="0,5,0,0" Classes="sub"
                                                   IsVisible="{Binding !HasOpenSessions}" />
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                            <Button Content="View Details" Click="ViewTaskDetails_Click"
                                                    Tag="{Binding Task}" HorizontalAlignment="Left" />
                                            <Button Content="Delete" Click="DeleteTask_Click" Tag="{Binding Task}"
                                                    HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <views:TaskDetailsView Name="TaskDetails" Margin="10,0,10,0" />
        </StackPanel>

    </DockPanel>
</UserControl>