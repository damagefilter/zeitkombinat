<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Zeitkombinat.Controls"
             xmlns:vm="using:Zeitkombinat.ViewModels"
             x:Class="Zeitkombinat.Views.TasksView">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,20">
            <!-- Story Details Section -->
            <StackPanel Name="StoryDisplayPanel" Spacing="5" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Name="StoryName" FontSize="18" FontWeight="Bold"/>
                    <Button Content="Edit" Click="EditStory_Click"/>
                </StackPanel>
                <TextBlock Name="StoryDescription"/>
                <HyperlinkButton 
                    Name="StoryLinkButton"
                    NavigateUri="--" 
                    Width="350"
                    Padding="0 5">
                    <TextBlock Name="StoryLinkLabel" Text="--" Margin="0" />
                </HyperlinkButton>
            </StackPanel>

            <!-- Story Edit Section -->
            <StackPanel Name="StoryEditPanel" Spacing="5" Margin="0,0,0,20" IsVisible="False">
                <TextBlock Text="Edit Story" FontSize="18" FontWeight="Bold"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="StoryNameEdit" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="StoryDescriptionEdit" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Link:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Name="StoryLinkEdit" Margin="0,0,0,5"/>

                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Save" Click="SaveStory_Click"/>
                        <Button Content="Cancel" Click="CancelStoryEdit_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Separator Margin="0,0,0,10"/>

            <TextBlock Text="Add New Task"/>
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" Name="TaskNameInput" Watermark="Task name" Margin="0,0,10,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Name="DescriptionInput" Watermark="Task description" Margin="0,0,10,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Link:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Name="HyperLinkInput" Watermark="Optional hyperlink" Margin="0,0,10,5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Estimated:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <controls:TimeSpanInput Grid.Row="3" Grid.Column="1" Name="EstimatedInput" Margin="0,0,10,5"/>

                <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="4" Content="Add Task" Click="AddTask_Click" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <ScrollViewer>
            <ItemsControl Name="TasksList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:TaskViewModel">
                        <Border BorderThickness="1" Margin="0,5" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Classes="h2"/>
                                <TextBlock Text="{Binding Description}" Margin="0,5,0,0"/>
                                
                                <HyperlinkButton 
                                    NavigateUri="{Binding RawLink}" 
                                    Width="350"
                                    Padding="0 5"
                                    IsVisible="{Binding HasLink}">
                                    <TextBlock Text="{Binding LinkText}" Margin="0" />
                                </HyperlinkButton>
                                
                                <TextBlock Margin="0,5,0,0" Classes="sub" IsVisible="{Binding HasOpenSessions}">
                                    <Run Text="{Binding HoursText}" />
                                    <Run Text=" - Open Sessions: " Classes="warning" />
                                    <Run Text="{Binding OpenSessionsDuration}" Classes="warning"/>
                                </TextBlock>
                                <TextBlock Text="{Binding HoursText}" Margin="0,5,0,0" Classes="sub" IsVisible="{Binding !HasOpenSessions}" />
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                    <Button Content="View Details" Click="ViewTaskDetails_Click" Tag="{Binding Task}" HorizontalAlignment="Left"/>
                                    <Button Content="Delete" Click="DeleteTask_Click" Tag="{Binding Task}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
