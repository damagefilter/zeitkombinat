<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zeitkombinat.ViewModels"
             x:Class="Zeitkombinat.Views.StoriesView">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,20">
            <!-- Project Details Section -->
            <StackPanel Name="ProjectDisplayPanel" Spacing="5" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Name="ProjectName" FontSize="18" FontWeight="Bold"/>
                    <Button Content="Edit" Click="EditProject_Click"/>
                </StackPanel>
                <TextBlock Name="ProjectDescription"/>
                <TextBlock Name="ProjectInvoiceMarker"/>
            </StackPanel>

            <!-- Project Edit Section -->
            <StackPanel Name="ProjectEditPanel" Spacing="5" Margin="0,0,0,20" IsVisible="False">
                <TextBlock Text="Edit Project" FontSize="18" FontWeight="Bold"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="ProjectNameEdit" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="ProjectDescriptionEdit" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Invoice Marker:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Name="ProjectInvoiceMarkerEdit" Margin="0,0,0,5"/>

                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Save" Click="SaveProject_Click"/>
                        <Button Content="Cancel" Click="CancelProjectEdit_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Separator Margin="0,0,0,10"/>

            <TextBlock Text="Add New Story" FontSize="16" FontWeight="Bold"/>
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" Margin="0,10,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" Name="StoryNameInput" Watermark="Story name" Margin="0,0,10,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Name="DescriptionInput" Watermark="Story description" Margin="0,0,10,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Link:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Name="HyperLinkInput" Watermark="Optional hyperlink" Margin="0,0,10,5"/>

                <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" Content="Add Story" Click="AddStory_Click" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <Grid ColumnDefinitions="*,*">
            <!-- Stories Column -->
            <ScrollViewer Grid.Column="0" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Stories" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ItemsControl Name="StoriesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:StoryViewModel">
                        <Border BorderThickness="1" Margin="0,5" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Classes="h2"/>
                                <TextBlock Text="{Binding Description}" Margin="0,5,0,0"/>
                                
                                <HyperlinkButton 
                                    NavigateUri="{Binding RawLink}" 
                                    Width="350"
                                    Padding="0 5"
                                    IsVisible="{Binding HasLink}">
                                    <TextBlock Text="{Binding LinkText}" Margin="0" />
                                </HyperlinkButton>
                                
                                <!-- <TextBlock Text="{Binding LinkText}" IsVisible="{Binding HasLink}"/> -->
                                <TextBlock Text="{Binding SummaryText}" Margin="0,10,0,0" Classes="sub"/>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                    <Button Content="View Tasks" Click="ViewTasks_Click" Tag="{Binding Story}" HorizontalAlignment="Left"/>
                                    <Button Content="Delete" Click="DeleteStory_Click" Tag="{Binding Story}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Invoices Column -->
            <ScrollViewer Grid.Column="1" Margin="10,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Invoices" FontSize="16" FontWeight="Bold" Margin="0,0,15,10"/>
                        <Button Content="Create Invoice" Click="CreateInvoice_Click" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <ItemsControl Name="InvoicesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:InvoiceViewModel">
                                <Border BorderThickness="1" Margin="0,5" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding BillingId}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CreationDateText}" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding HourlyRateText}" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding TotalAmountText}" FontWeight="Bold" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
