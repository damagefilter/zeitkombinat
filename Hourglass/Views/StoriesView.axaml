<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hourglass.ViewModels"
             x:Class="Hourglass.Views.StoriesView">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,20">
            <TextBlock Text="Add New Story" FontSize="16" FontWeight="Bold"/>
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" Margin="0,10,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" Name="StoryNameInput" Watermark="Story name" Margin="0,0,10,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Name="DescriptionInput" Watermark="Story description" Margin="0,0,10,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Link:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Name="HyperLinkInput" Watermark="Optional hyperlink" Margin="0,0,10,5"/>

                <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" Content="Add Story" Click="AddStory_Click" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <ScrollViewer>
            <ItemsControl Name="StoriesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:StoryViewModel">
                        <Border BorderThickness="1" Margin="0,5" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Text="{Binding Description}" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding LinkText}" IsVisible="{Binding HasLink}"/>
                                <TextBlock Text="{Binding SummaryText}" Margin="0,10,0,0"/>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                    <Button Content="View Tasks" Click="ViewTasks_Click" Tag="{Binding Story}" HorizontalAlignment="Left"/>
                                    <Button Content="Delete" Click="DeleteStory_Click" Tag="{Binding Story}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
