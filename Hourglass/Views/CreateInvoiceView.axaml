<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Hourglass.ViewModels"
             x:Class="Hourglass.Views.CreateInvoiceView">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,20">
            <TextBlock Name="ProjectTitle" FontSize="18" FontWeight="Bold"/>
            
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,10,0,10">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Hourly Rate:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" Name="HourlyRateInput" Watermark="e.g. 50.00" Width="200" HorizontalAlignment="Left"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Filter Tasks:" VerticalAlignment="Center" Margin="0,10,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Name="FilterInput" Watermark="Search by name or description" Margin="0,10,0,0" TextChanged="FilterInput_TextChanged"/>
            </Grid>

            <Separator Margin="0,10,0,10"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Create Invoice" Click="CreateInvoice_Click" HorizontalAlignment="Left"/>
                <Button Content="Cancel" Click="Cancel_Click" HorizontalAlignment="Left"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer>
            <ItemsControl Name="TasksList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:InvoiceTaskItemViewModel">
                        <Border BorderThickness="1" Margin="0,5" Padding="10">
                            <StackPanel>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding StoryName}" FontSize="12" Foreground="Gray"/>
                                        <TextBlock Text="{Binding TaskName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding TaskDescription}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="10,0">
                                        <TextBlock Text="Unbilled Hours:" FontSize="12"/>
                                        <TextBlock Text="{Binding UnbilledHoursText}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Override Rate:" FontSize="12"/>
                                        <TextBox Name="RateOverrideInput" Watermark="Optional" Width="100" 
                                                 LostFocus="RateOverride_LostFocus" Tag="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
