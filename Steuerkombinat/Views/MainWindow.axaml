<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Steuerkombinat.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Steuerkombinat.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Steuerkombinat">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left side: Input section -->
        <StackPanel Grid.Column="0">
            <TextBlock Text="Current KV (Monthly):" Margin="0,0,0,5"/>
            <TextBox Text="{Binding CurrentKv}" Width="200" Margin="0,0,0,30"/>

            <TextBlock Text="Invoice Amount (Euro):" Margin="0,0,0,5"/>
            <TextBox Text="{Binding InvoiceAmount}" Width="200" Margin="0,0,0,15"/>

            <TextBlock Text="Invoice Number:" Margin="0,0,0,5"/>
            <TextBox Text="{Binding InvoiceNumber}" Width="200" Margin="0,0,0,30"/>

            <StackPanel Margin="0,0,0,15">
                <TextBlock Margin="0,0,0,5">
                    <Run Text="KV: "/>
                    <Run Text="{Binding Kv, StringFormat={}{0:F2}}"/>
                    <Run Text=" €"/>
                </TextBlock>

                <TextBlock Margin="0,0,0,5">
                    <Run Text="EKS: "/>
                    <Run Text="{Binding Eks, StringFormat={}{0:F2}}"/>
                    <Run Text=" €"/>
                </TextBlock>
                
                <TextBlock Margin="0,0,0,5">
                    <Run Text="Max Payout: "/>
                    <Run Text="{Binding MaxPayout, StringFormat={}{0:F2}}"/>
                    <Run Text=" €"/>
                </TextBlock>
            </StackPanel>

            <Button Content="Add" Command="{Binding AddInvoiceCommand}" Width="200"/>

            <TextBlock Text="Yearly Total" FontWeight="Bold" FontSize="16" Margin="0,30,0,10"/>
            <StackPanel>
                <TextBlock Margin="0,0,0,5">
                    <Run Text="Total: "/>
                    <Run Text="{Binding YearlyTotal, StringFormat={}{0:F2}}"/>
                    <Run Text=" €"/>
                </TextBlock>

                <TextBlock Margin="0,0,0,5">
                    <Run Text="KV: "/>
                    <Run Text="{Binding YearlyKv, StringFormat={}{0:F2}}"/>
                    <Run Text=" €"/>
                </TextBlock>

                <TextBlock Margin="0,0,0,5">
                    <Run Text="EKS: "/>
                    <Run Text="{Binding YearlyEks, StringFormat={}{0:F2}}"/>
                    <Run Text=" €"/>
                </TextBlock>
                
            </StackPanel>
        </StackPanel>

        <!-- Right side: Invoices list -->
        <StackPanel Grid.Column="2">
            <!-- Selected invoice details -->
            <Border BorderBrush="DarkGray" BorderThickness="2" Padding="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,10">
                        <Run>Selected Invoice:</Run>
                        <Run Text="{Binding SelectedInvoice.InvoiceNumber, FallbackValue=None}"></Run>
                    </TextBlock>
                    <TextBlock Margin="0,0,0,5">
                        <Run Text="Invoice Total: "/>
                        <Run Text="{Binding SelectedInvoiceAmount, StringFormat={}{0:F2}}"/>
                        <Run Text=" €"/>
                    </TextBlock>
                    <TextBlock Margin="0,0,0,5">
                        <Run Text="KV: "/>
                        <Run Text="{Binding SelectedKv, StringFormat={}{0:F2}}"/>
                        <Run Text=" €"/>
                    </TextBlock>
                    <TextBlock Margin="0,0,0,5">
                        <Run Text="EKS: "/>
                        <Run Text="{Binding SelectedEks, StringFormat={}{0:F2}}"/>
                        <Run Text=" €"/>
                    </TextBlock>
                    <TextBlock Margin="0,0,0,5" FontWeight="Bold">
                        <Run Text="Max Payout: "/>
                        <Run Text="{Binding SelectedMaxPayout, StringFormat={}{0:F2}}"/>
                        <Run Text=" €"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Invoices list -->
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Invoices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10"
                                    Background="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectedInvoice, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={Binding}, FallbackValue=Transparent}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            BorderThickness="0"
                                            Padding="0"
                                            Cursor="Hand"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectInvoiceCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding InvoiceNumber}" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Date, StringFormat='Date: {0:dd.MM.yyyy HH:mm}'}" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Amount, StringFormat='Amount: {0:F2} €'}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Content="Delete"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteInvoiceCommand}"
                                            CommandParameter="{Binding}"
                                            VerticalAlignment="Center"
                                            Margin="10,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>

</Window>
